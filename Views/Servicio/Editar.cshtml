@model SistemaGestionCitas.Models.Servicio

@{
    ViewData["Title"] = "Editar Servicio";
}

<h2><i class="fas fa-edit"></i> Editar Servicio</h2>

<div class="row mt-4">
    <div class="col-md-6">
        <form asp-action="Editar" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="DuracionMinutos" class="form-label"></label>
                <input asp-for="DuracionMinutos" type="number" class="form-control" />
                <span asp-validation-for="DuracionMinutos" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Costo" class="form-label"></label>
                <input asp-for="Costo" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Costo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <input asp-for="Activo" class="form-check-input" type="checkbox" />
                    <label asp-for="Activo" class="form-check-label">Servicio Activo</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Guardar Cambios
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
