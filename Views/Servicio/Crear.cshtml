@model SistemaGestionCitas.Models.Servicio

@{
    ViewData["Title"] = "Crear Servicio";
}

<h2><i class="fas fa-briefcase"></i> Crear Servicio</h2>

<div class="row mt-4">
    <div class="col-md-6">
        <form asp-action="Crear" method="post">
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej: Consulta General" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Descripción del servicio"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="DuracionMinutos" class="form-label"></label>
                <input asp-for="DuracionMinutos" type="number" class="form-control" placeholder="Ej: 30" />
                <span asp-validation-for="DuracionMinutos" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Costo" class="form-label"></label>
                <input asp-for="Costo" type="number" step="0.01" class="form-control" placeholder="Ej: 5000.00" />
                <span asp-validation-for="Costo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <input asp-for="Activo" class="form-check-input" type="checkbox" checked />
                    <label asp-for="Activo" class="form-check-label">Servicio Activo</label>
                </div>
            </div>

            <div class="mb-4 d-flex gap-2">
            <button type="submit" class="btn btn-success">
                <i class="fas fa-save"></i> Guardar
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Cancelar
            </a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
