@model IEnumerable<SistemaGestionCitas.Models.Servicio>

@{
    ViewData["Title"] = "Servicios";
}

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert"
         style="border-radius:12px; border-left: 4px solid #5ecba1;">
        <i class="fas fa-check-circle"></i> @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-briefcase"></i> Lista de Servicios</h2>
    @if (Context.Session.GetString("UsuarioRol") == "Administrador")
    {
        <a asp-action="Crear" class="btn btn-success">
            <i class="fas fa-plus"></i> Nuevo Servicio
        </a>
    }
</div>

@if (Model.Any())
{
    <table class="table table-hover table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Duración (min)</th>
                <th>Costo</th>
                <th>Estado</th>
                @if (Context.Session.GetString("UsuarioRol") == "Administrador")
                {
                    <th>Acciones</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var servicio in Model)
            {
                <tr>
                    <td>@servicio.Id</td>
                    <td>@servicio.Nombre</td>
                    <td>@servicio.Descripcion</td>
                    <td>@servicio.DuracionMinutos</td>
                    <td>@servicio.Costo.ToString("C")</td>
                    <td>
                        @if (servicio.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactivo</span>
                        }
                    </td>
                    @if (Context.Session.GetString("UsuarioRol") == "Administrador")
                    {
                        <td>
                            <a asp-action="Editar" asp-route-id="@servicio.Id" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Eliminar" asp-route-id="@servicio.Id" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        No hay servicios registrados.
        @if (Context.Session.GetString("UsuarioRol") == "Administrador")
        {
            <a asp-action="Crear">Crear el primero</a>
        }
    </div>
}