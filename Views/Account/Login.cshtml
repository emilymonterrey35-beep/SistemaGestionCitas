@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Nunito', sans-serif;
            min-height: 100vh;
            background: linear-gradient(135deg, #e8e4ff 0%, #fce4ec 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 8px 32px rgba(108, 93, 211, 0.15);
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 400px;
            animation: fadeUp 0.4s ease both;
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .login-icon {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #7c6fe0, #f48fb1);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            font-size: 1.6rem;
            color: white;
        }

        .login-title {
            font-weight: 800;
            font-size: 1.5rem;
            color: #3d3560;
            text-align: center;
            margin-bottom: 0.3rem;
        }

        .login-subtitle {
            text-align: center;
            color: #9b93c8;
            font-size: 0.85rem;
            margin-bottom: 1.8rem;
        }

        .form-label {
            font-weight: 700;
            font-size: 0.85rem;
            color: #3d3560;
        }

        .form-control {
            border: 1.5px solid #e4e0f7;
            border-radius: 12px;
            padding: 0.6rem 1rem;
            font-family: 'Nunito', sans-serif;
            transition: border 0.2s, box-shadow 0.2s;
        }

        .form-control:focus {
            border-color: #a99de8;
            box-shadow: 0 0 0 3px rgba(124, 111, 224, 0.15);
            outline: none;
        }

        .btn-login {
            background: linear-gradient(135deg, #7c6fe0, #9b8ff0);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 0.65rem;
            font-family: 'Nunito', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            width: 100%;
            margin-top: 0.5rem;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 4px 14px rgba(124, 111, 224, 0.35);
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(124, 111, 224, 0.45);
            color: white;
        }

        .footer-text {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.78rem;
            color: #c5bef7;
        }
    </style>
</head>
<body>
    <div class="login-card">

        <div class="login-icon">
            <i class="fa-solid fa-calendar-check"></i>
        </div>

        <h3 class="login-title">Sistema de Citas</h3>
        <p class="login-subtitle">Inicia sesión para continuar</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger" style="border-radius:12px; font-size:.88rem;">
                <i class="fa-solid fa-circle-exclamation"></i> @ViewBag.Error
            </div>
        }

        <form method="post" asp-action="Login">
            <div class="mb-3">
                <label class="form-label">
                    <i class="fa-solid fa-envelope" style="color:#9b93c8; margin-right:5px;"></i>Correo
                </label>
                <input type="email" name="correo" class="form-control" placeholder="tu@correo.com" required />
            </div>

            <div class="mb-3">
                <label class="form-label">
                    <i class="fa-solid fa-lock" style="color:#9b93c8; margin-right:5px;"></i>Contraseña
                </label>
                <input type="password" name="contrasena" class="form-control" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn-login">
                Entrar
            </button>
        </form>

        <p class="footer-text">✨ Sistema de Gestión de Citas © @DateTime.Now.Year</p>
    </div>
</body>
</html>