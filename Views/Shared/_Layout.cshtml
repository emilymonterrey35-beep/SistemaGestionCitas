<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Gestión de Citas</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            font-family: 'Nunito', sans-serif;
            background-color: #f8f7ff;
        }

        .navbar {
            background-color: #7c6fe0 !important;
        }

        .navbar-brand, .nav-link {
            color: white !important;
            font-weight: 600;
        }

            .nav-link:hover {
                color: #e0d9ff !important;
            }

        .btn-primary {
            background-color: #7c6fe0;
            border-color: #7c6fe0;
            border-radius: 10px;
            font-weight: 600;
        }

            .btn-primary:hover {
                background-color: #6c5dd3;
                border-color: #6c5dd3;
            }

        .btn-success {
            border-radius: 10px;
            font-weight: 600;
        }

        .btn-danger {
            border-radius: 10px;
            font-weight: 600;
        }

        .btn-secondary {
            border-radius: 10px;
            font-weight: 600;
        }

        .card {
            border-radius: 16px;
            border: 1px solid #e0d9ff;
        }

        .form-control, .form-select {
            border-radius: 10px;
            border: 1.5px solid #d0c9f0;
        }

            .form-control:focus, .form-select:focus {
                border-color: #7c6fe0;
                box-shadow: 0 0 0 3px rgba(124, 111, 224, 0.15);
            }

        .table thead th {
            background-color: #f0eeff;
            color: #5a4fcf;
            font-weight: 700;
        }

        footer {
            text-align: center;
            padding: 1rem;
            font-size: 0.85rem;
            color: #aaa;
            border-top: 1px solid #e0d9ff;
            margin-top: 2rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Dashboard">
                <i class="fas fa-calendar-check"></i> Sistema de Citas
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Dashboard">
                            <i class="fas fa-home"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Cliente" asp-action="Index">
                            <i class="fas fa-users"></i> Clientes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Servicio" asp-action="Index">
                            <i class="fas fa-briefcase"></i> Servicios
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button"
                           data-bs-toggle="dropdown">
                            <i class="fas fa-user"></i> Usuario
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
        &copy; 2026 - Sistema de Gestión de Citas -
        <a asp-controller="Home" asp-action="Privacy">Privacidad</a>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>